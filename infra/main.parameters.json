{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "crashGmiApiKey": {
      "value": "${CRASH_GMI_API_KEY}"
    },
    "crashAzureOpenAiEndpoint": {
      "value": "${CRASH_AZURE_OPENAI_ENDPOINT}"
    },
    "crashAzureOpenAiKey": {
      "value": "${CRASH_AZURE_OPENAI_KEY}"
    },
    "crashAzureOpenAiDeployment": {
      "value": "${CRASH_AZURE_OPENAI_DEPLOYMENT}"
    },
    "crashX402Wallet": {
      "value": "${CRASH_X402_WALLET}"
    },
    "crashGithubModelsToken": {
      "value": "${CRASH_GITHUB_MODELS_TOKEN}"
    },
    "crashTavilyApiKey": {
      "value": "${CRASH_TAVILY_API_KEY}"
    },
    "crashAzureOpenAiApiVersion": {
      "value": "${CRASH_AZURE_OPENAI_API_VERSION}"
    },
    "crashGithubModelsEndpoint": {
      "value": "${CRASH_GITHUB_MODELS_ENDPOINT}"
    },
    "crashGithubModelsModel": {
      "value": "${CRASH_GITHUB_MODELS_MODEL}"
    },
    "crashGmiModel": {
      "value": "${CRASH_GMI_MODEL}"
    }
  }
}
