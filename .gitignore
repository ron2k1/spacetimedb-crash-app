# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Local secrets -- GMI/Phinite hackathon tester key for the Test-Agent demo flow. NEVER commit.
# The tracked template is .env.example; real values live only in the gitignored .env.
.env
.env.*
!.env.example

# Vite config-bundle fallback (when node_modules\.vite-temp\ mkdir EPERMs on
# Windows -- Defender RTP or chokidar handle. Vite writes the bundled config
# next to vite.config.ts instead, and the .unlink() in the finally block is
# best-effort -- if EPERM races there too, the file persists.)
vite.config.*.timestamp-*.mjs

# TypeScript composite-mode incremental build info. tsconfig.node.json has
# `composite: true`, so `tsc -p tsconfig.node.json --noEmit` still emits
# *.tsbuildinfo despite --noEmit (composite overrides the no-output guarantee).
*.tsbuildinfo

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Rust / Tauri build output (now under frontend/r3f-shell/src-tauri)
target/
# Tauri generated schemas
gen/schemas/
# pnpm store debug
.pnpm-debug.log*

# Verification / scratch screenshots -- not product assets. Real doc images live under
# docs/screenshots/ (tracked). These dirs are throwaway capture output from dev sessions.
# Leading slash anchors each to the repo root so an unanchored `screenshots/` does not
# also swallow the tracked docs/screenshots/ tree.
/.crash-shots/
/screenshots/

# Stray Windows /dev/null redirection artifact: a hook/script redirected to
# "dev/null" (no leading slash), which on Windows creates ./dev/null/* in-repo
# instead of discarding to the null device. Not source; ignore the whole dir.
/dev/

# Local Codex/Crash verification artifacts from desktop repair sessions.
/.codex-crash-visual-check.png
/.codex-sidecar-probe.err
/.codex-sidecar-probe.out

# Design-tool component staging area. Components are pasted here from the design tool, then
# the production copy is hand-placed under src/components/ui|blocks/. Only the production
# copy is tracked; this incoming/ tree is a scratch inbox.
docs/incoming-components/

# Superpowers brainstorming-companion UI state (throwaway: cards.html, server-stopped flags).
# Generated by the brainstorming visual companion; not source.
.superpowers/

# Crash engine single-exe (Node SEA), produced by installer/build-engine-exe.mjs before
# `cargo build` / `tauri build`. A ~70 MB build artifact -- never committed; CI (release.yml)
# rebuilds it per release, and a local build regenerates it on demand.
frontend/r3f-shell/src-tauri/binaries/*.exe
# Intermediate SEA staging (esbuild CJS bundle, sea-config.json, sea-prep.blob).
backend/.sea-build/
# Staged Tauri resource: a build-time copy of backend/catalog/ that bundle.resources ships into
# the installer. installer/build-engine-exe.mjs regenerates it each build; backend/catalog/ is the
# tracked source of truth, so this copy is a derived artifact and must not be committed.
frontend/r3f-shell/src-tauri/catalog/
