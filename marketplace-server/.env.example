# Crash marketplace-server -- environment template
#
# Copy this file to `.env` (same folder) and fill in the values you have. `.env` is gitignored;
# NEVER commit real keys. The server loads this .env automatically on a direct launch (npm start /
# tsx dev) and a single restart brings every tier below live. On Azure these same names become
# Container App settings (see infra/main.bicep + DEPLOY.md) -- the contract is identical.
#
# Everything is OPTIONAL: with nothing set, the server runs fully (offline inference + a canned
# search brief) so the demo never hard-fails. Each key you add upgrades one tier to a real API.

# ----------------------------------------------------------------------------
# INFERENCE  (precedence: Azure OpenAI -> GitHub Models -> GMI -> offline)
# Set ANY ONE tier to get real LLM synthesis. /api/config reports which one is live.
# ----------------------------------------------------------------------------

# Tier 1 -- Azure OpenAI. All three are required together for this tier to activate.
CRASH_AZURE_OPENAI_ENDPOINT=
CRASH_AZURE_OPENAI_KEY=
CRASH_AZURE_OPENAI_DEPLOYMENT=
# Optional override; defaults to a known-good API version when omitted.
CRASH_AZURE_OPENAI_API_VERSION=

# Tier 2 -- GitHub Models (models.github.ai, OpenAI-compatible, Azure-hosted). A GitHub PAT is the
# lowest-friction real inference for a GitHub/Microsoft event -- this is the demo's default live tier.
CRASH_GITHUB_MODELS_TOKEN=
# Optional overrides; sensible defaults are used when omitted.
CRASH_GITHUB_MODELS_ENDPOINT=
CRASH_GITHUB_MODELS_MODEL=

# Tier 3 -- GMI serving (OpenAI-compatible). Fallback inference provider.
CRASH_GMI_API_KEY=
# Optional override; defaults to a known-good model id when omitted.
CRASH_GMI_MODEL=

# ----------------------------------------------------------------------------
# SEARCH  (precedence: x402 paid -> key-auth Tavily -> canned offline brief)
# Set EITHER one to get real web search. /api/config reports which one is live.
# ----------------------------------------------------------------------------

# Tier 1 -- x402 paid search. A FUNDED Base Sepolia (eip155:84532) wallet private key. The run pays a
# 0.01 USDC testnet micropayment to the keyless Tavily x402 endpoint and settles onchain with a real
# txRef. Present-but-unfunded -> the run falls through to the tier below (no fabricated settle).
CRASH_X402_WALLET=

# Tier 2 -- key-auth Tavily (api.tavily.com). A free Tavily API key (tavily.com, ~2 min) gives REAL
# web search with NO wallet/funding. Billed to the account, not onchain -> no payment beat is emitted.
# This is the fastest path from "canned brief" to "live cited results".
CRASH_TAVILY_API_KEY=

# ----------------------------------------------------------------------------
# SERVER
# ----------------------------------------------------------------------------
# Port to listen on. Defaults to 8787 locally; Azure Container Apps injects PORT automatically.
PORT=
